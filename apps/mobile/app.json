{
  "expo": {
    "name": "World Cup 2026",
    "slug": "worldcup-2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "worldcup2026",
    "userInterfaceStyle": "automatic",
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
